# 应用配置
APP_NAME=SoLove Backend
APP_VERSION=0.1.0
DEBUG=True

# 服务配置
HOST=0.0.0.0
PORT=8000

# 数据库配置（本地 MySQL，请按实际用户/密码/库名修改）
DATABASE_URL=mysql+pymysql://solove:solove_password@localhost:3306/solove?charset=utf8mb4

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# JWT 配置（生产环境务必修改）
SECRET_KEY=your-secret-key-change-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI 配置（后续接入）
AI_API_KEY=
AI_API_BASE=
AI_MODEL=qwen-plus

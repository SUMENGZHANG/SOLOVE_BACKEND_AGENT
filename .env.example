# 应用配置
APP_NAME=SoLove Backend
APP_VERSION=0.1.0
DEBUG=True

# 服务配置
HOST=0.0.0.0
PORT=8000

# 数据库配置（本地 MySQL，请按实际用户/密码/库名修改）
DATABASE_URL=mysql+pymysql://solove:solove_password@localhost:3306/solove?charset=utf8mb4

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# JWT 配置（生产环境务必修改）
SECRET_KEY=your-secret-key-change-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI 配置（阿里云 DashScope / Qwen）
# 获取 API Key: https://dashscope.console.aliyun.com/apiKey
# 文档：https://help.aliyun.com/zh/dashscope/developer-reference/compatibility-of-openai-with-dashscope
AI_API_KEY=your-dashscope-api-key
AI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-plus
